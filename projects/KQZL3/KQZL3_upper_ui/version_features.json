{
  "_comment": "KQZL3 upper UI features by firmware version. Core runtime files stay in alwaysInclude so exported versions remain independently buildable.",
  "defaultFeatures": ["common"],
  "alwaysInclude": [
    "package.json",
    "package-lock.json",
    "vite.config.js",
    "index.html",
    "capacitor.config.json",
    "version_features.json",
    "src/main.js",
    "src/App.vue",
    "src/manifest.json",
    "src/pages.json",
    "src/uni.scss",
    "src/static/**",
    "src/components/**",
    "src/features/index.js",
    "src/config/**",
    "src/services/**",
    "src/pages/**"
  ],
  "featureGlobs": {
    "common": ["src/features/common.js"],
    "dht11": [],
    "mq2": [],
    "mq7": [],
    "remote": ["src/features/remote.js"],
    "wifi": ["src/features/wifi.js"],
    "ble": ["src/features/ble.js"],
    "app": ["src/features/app.js"],
    "aliyun": ["src/features/aliyun.js"],
    "mpWeixin": ["src/features/mpWeixin.js"],
    "web": ["src/features/web.js"]
  },
  "versions": {
    "default": { "features": ["common"] },
    "1": { "features": ["common"] },
    "2": { "features": ["common", "dht11"] },
    "3": { "features": ["common", "dht11", "remote", "wifi", "app"] },
    "4": { "features": ["common", "dht11", "remote", "ble", "app"] },
    "5": { "features": ["common", "dht11", "mq2"] },
    "6": { "features": ["common", "dht11", "mq2", "remote", "wifi", "app"] },
    "7": { "features": ["common", "dht11", "mq2", "remote", "ble", "app"] },
    "8": { "features": ["common", "dht11", "mq2", "remote", "wifi", "aliyun", "app"] },
    "9": { "features": ["common", "dht11", "mq2", "remote", "wifi", "mpWeixin"] },
    "10": { "features": ["common", "dht11", "mq2", "remote", "wifi", "web"] },
    "11": { "features": ["common", "dht11", "mq2", "mq7"] },
    "12": { "features": ["common", "dht11", "mq2", "mq7", "remote", "wifi", "app"] },
    "13": { "features": ["common", "dht11", "mq2", "mq7", "remote", "ble", "app"] },
    "14": { "features": ["common", "dht11", "mq2", "mq7", "remote", "wifi", "aliyun", "app"] }
  }
}
